PORT=5000
NODE_ENV=development

# Use long, unique values from a secret manager. Production requires both values.
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-at-least-32-random-characters
JWT_ISSUER=bites-api
JWT_AUDIENCE=bites-platform

# Comma-separated browser origins. Never use * in production.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

DB_HOST=127.0.0.1
DB_USER=app_user
DB_PASSWORD=replace-with-a-secret
DB_NAME=food_delivery_platform
DB_SSL_CA=

# Set one TLS approach in production: local TLS files, or a trusted reverse proxy.
TLS_ENABLED=false
TLS_KEY_PATH=
TLS_CERT_PATH=
TLS_CA_PATH=
TRUSTED_TLS_PROXY=false
